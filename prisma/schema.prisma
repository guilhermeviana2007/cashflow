// Schema do Cash Flow
// Banco: SQLite (arquivo local, sem servidor) — fácil de evoluir para Postgres depois.
// Obs: SQLite no Prisma não suporta enums, então usamos campos String validados na aplicação.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Dono de conta do SaaS. Faz login com email + senha.
model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  senhaHash String
  createdAt DateTime @default(now())

  // Segurança / recuperação de conta
  telefone                   String?
  emailRecuperacao           String?
  emailRecuperacaoVerificado Boolean   @default(false)
  tokenVerificacao           String?
  tokenVerificacaoExpira     DateTime?

  estabelecimentos Estabelecimento[]
  sessoes          Sessao[]
  assinatura       Assinatura?
}

// Assinatura do cliente (1 por usuário). Gestão manual pelo admin.
model Assinatura {
  id                String   @id @default(cuid())
  usuarioId         String   @unique
  usuario           Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  status            String   @default("ATIVA")  // "ATIVA" | "PAUSADA" | "CANCELADA"
  plano             String   @default("MENSAL") // "MENSAL" | "TRIMESTRAL" | "ANUAL"
  valorCentavos     Int      @default(0)
  proximoVencimento DateTime

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  pagamentos        Pagamento[]
}

// Histórico de pagamentos registrados manualmente pelo admin.
model Pagamento {
  id            String     @id @default(cuid())
  assinaturaId  String
  assinatura    Assinatura @relation(fields: [assinaturaId], references: [id], onDelete: Cascade)
  valorCentavos Int
  dataPagamento DateTime   @default(now())
  referencia    String?    // ex: "Junho/2026" ou observação
  createdAt     DateTime   @default(now())

  @@index([assinaturaId])
}

// Sessão de login. O id é o token guardado no cookie do navegador.
model Sessao {
  id        String   @id
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  expiraEm  DateTime
  createdAt DateTime @default(now())

  @@index([usuarioId])
}

// Cada estabelecimento pertence a um usuário.
model Estabelecimento {
  id        String   @id @default(cuid())
  nome      String
  tipo      String
  createdAt DateTime @default(now())

  // Saldo inicial do caixa — base para calcular o saldo atual.
  saldoInicialCentavos Int      @default(0)
  saldoInicialData     DateTime?

  // Foto/avatar do estabelecimento (data URL base64)
  fotoPerfil           String?

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  categorias      Categoria[]
  lancamentos     Lancamento[]
  formasPagamento FormaPagamento[]
  custosFixos     CustoFixo[]
  produtosEstoque ProdutoEstoque[]
  marketplaces    Marketplace[]

  @@index([usuarioId])
}

// Plano de contas — classifica cada lançamento.
model Categoria {
  id        String @id @default(cuid())
  nome      String
  tipo      String  // "ENTRADA" | "SAIDA"
  grupoDre  String  // "RECEITA_BRUTA" | "DEDUCAO" | "CMV" | "DESPESA_OPERACIONAL" | "OUTRA_RECEITA" | "OUTRA_DESPESA"

  estabelecimentoId String
  estabelecimento   Estabelecimento @relation(fields: [estabelecimentoId], references: [id], onDelete: Cascade)

  lancamentos Lancamento[]
  custosFixos CustoFixo[]

  @@index([estabelecimentoId])
}

// Entrada (venda/receita) ou Saída (compra/despesa) no caixa.
model Lancamento {
  id             String   @id @default(cuid())
  tipo           String   // "ENTRADA" | "SAIDA"
  descricao      String
  valorCentavos  Int
  taxaDescontadaCentavos Int @default(0) // taxa já calculada e descontada neste lançamento
  data           DateTime
  fornecedor     String?
  formaPagamento String?  // slug da FormaPagamento (ex: "debito", "credito", "pix")
  origem         String   @default("MANUAL") // "MANUAL" | "UPLOAD" | "WHATSAPP" | "CUSTO_FIXO"
  status         String   @default("CONFIRMADO") // "PENDENTE" | "CONFIRMADO"
  createdAt      DateTime @default(now())

  categoriaId String?
  categoria   Categoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)

  custoFixoId String?
  custoFixo   CustoFixo? @relation(fields: [custoFixoId], references: [id], onDelete: SetNull)

  estabelecimentoId String
  estabelecimento   Estabelecimento @relation(fields: [estabelecimentoId], references: [id], onDelete: Cascade)

  @@index([estabelecimentoId, data])
  @@index([estabelecimentoId, tipo, data])
  @@index([categoriaId])
}

// Formas de pagamento com taxa configurável (Dinheiro, PIX, Cartão, iFood, etc.).
// Slugs fixos por estabelecimento — seeded no cadastro.
// percentualCentesimos: 320 = 3.20%
model FormaPagamento {
  id                   String          @id @default(cuid())
  slug                 String          // "dinheiro" | "pix" | "debito" | "credito" | "voucher" | "ifood" | "99food" | ...
  nome                 String          // "Dinheiro", "PIX", "Cartão de Débito", etc.
  percentualCentesimos Int             @default(0)

  estabelecimentoId    String
  estabelecimento      Estabelecimento @relation(fields: [estabelecimentoId], references: [id], onDelete: Cascade)

  @@unique([estabelecimentoId, slug])
  @@index([estabelecimentoId])
}

// Item de estoque: produto industrializado ou insumo. Contagem feita
// diariamente pelo usuário; avisa quando fica abaixo do mínimo ideal.
model ProdutoEstoque {
  id              String   @id @default(cuid())
  nome            String
  tipo            String   // "INDUSTRIALIZADO" | "INSUMO"
  unidade         String   @default("un") // un, kg, L, cx, pct...
  quantidadeAtual Float    @default(0)
  quantidadeIdeal Float    @default(0) // mínimo ideal para o aviso
  createdAt       DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  estabelecimentoId String
  estabelecimento   Estabelecimento @relation(fields: [estabelecimentoId], references: [id], onDelete: Cascade)

  @@index([estabelecimentoId])
}

// Formulário público de onboarding do MenuPro (cardápio digital).
// Não tem login — qualquer cliente preenche pelo link público e cai no painel admin.
model FormularioMenuPro {
  id                  String   @id @default(cuid())
  nomeResponsavel     String
  telefone            String
  email               String
  cnpj                String
  nomeEstabelecimento String
  marketplaces        String   // texto livre (iFood, 99Food, etc.)
  trabalhaMesas       String   // "Sim" | "Não"
  entregaPropria      String   // "Sim" | "Não"
  cardapioLogin       String?
  cardapioSenha       String?
  ifoodLogin          String?
  ifoodSenha          String?
  noveNoveLogin       String?
  noveNoveSenha       String?
  telefoneLoja        String?  // WhatsApp/telefone do estabelecimento (diferente do pessoal)
  cep                 String?
  logradouro          String?
  numero              String?
  complemento         String?
  bairro              String?
  cidade              String?
  estado              String?
  horarioFuncionamento String? // "Seg: 09:00–22:00 | ... | Dom: Fechado"
  formasPagamento     String?  // formas de pagamento aceitas (texto separado por vírgula)
  taxaEntrega         String?  // como organiza as taxas: por bairro / distância / fixa / não faz
  sistemaFinanceiro   String?  // já possui sistema financeiro/fluxo de caixa?
  canaisAtendimento   String?  // canais de atendimento atuais
  temFotos            String   // "Sim" | "Não" | "Parcial"

  // Conta de repasses (Pix automático do cardápio)
  repasseTipoDocumento   String? // "CPF" | "CNPJ"
  repasseDocumento       String?
  repasseNomeCompleto    String?
  repasseDataNascimento  String?
  repasseOcupacao        String?
  repasseNomeMae         String?
  repasseCep             String?
  repasseEndereco        String?
  repasseNumero          String?
  repasseComplemento     String?
  repasseBairro          String?
  repasseCidade          String?
  repasseEstado          String?
  repasseTipoChavePix    String?
  repasseChavePix        String?
  repasseBanco           String?
  repasseTipoConta       String? // "Conta Corrente" | "Conta Poupança"
  repasseAgencia         String?
  repasseConta           String?
  repasseEmail           String?
  repasseCelular         String?
  lido                Boolean  @default(false)
  createdAt           DateTime @default(now())

  @@index([createdAt])
}

// Canal de delivery (iFood, Rappi, etc.) — cada estabelecimento ativa os que usa.
model Marketplace {
  id                String   @id @default(cuid())
  nome              String
  ativo             Boolean  @default(true)
  createdAt         DateTime @default(now())

  estabelecimentoId String
  estabelecimento   Estabelecimento @relation(fields: [estabelecimentoId], references: [id], onDelete: Cascade)

  @@index([estabelecimentoId])
}

// Custo fixo recorrente (aluguel, energia, salário, etc.).
// Lançamentos são gerados automaticamente todo mês no diaVencimento.
model CustoFixo {
  id                String   @id @default(cuid())
  nome              String
  valorCentavos     Int
  diaVencimento     Int      // 1-28
  ativo             Boolean  @default(true)
  createdAt         DateTime @default(now())

  categoriaId String?
  categoria   Categoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)

  estabelecimentoId String
  estabelecimento   Estabelecimento @relation(fields: [estabelecimentoId], references: [id], onDelete: Cascade)

  lancamentos Lancamento[]

  @@index([estabelecimentoId])
}
